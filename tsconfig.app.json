{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  // Upstream submodule files are type-checked via tsconfig.upstream.json
  // (relaxed strict mode). We reference that project from tsconfig.json so
  // vue-tsc --build builds both. Our own src/ stays under full strictness here.
  "include": [
    "env.d.ts",
    "src/**/*",
    "src/**/*.vue"
  ],
  "exclude": ["src/**/__tests__/*"],
  "references": [
    { "path": "./tsconfig.upstream.json" }
  ],
  "compilerOptions": {
    // Composite required so tsconfig.app.json can reference tsconfig.upstream.json.
    "composite": true,

    // Extra safety for array and object lookups, but may have false positives.
    "noUncheckedIndexedAccess": true,

    // Path mapping for cleaner imports.
    "paths": {
      "@/*": ["./src/*"],
      "@upstream/*": ["./vendor/claude-hud/src/*"]
    },

    // Upstream submodule uses ".js" import extensions (TS-emit convention).
    // Bundler resolution lets Vite/vue-tsc map them back to the .ts sources.
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,

    // Upstream source uses Node built-ins (node:fs etc.). We only import
    // colors.ts at runtime (zero Node deps), but type-check needs Node types.
    "types": ["node"],

    // `vue-tsc --build` produces a .tsbuildinfo file for incremental type-checking.
    // Specified here to keep it out of the root directory.
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo"
  }
}
